{
  "name": "Pyrogram Message Reporter",
  "description": "Reports a specific Telegram message using Pyrogram.",
  "repository": "https://github.com/yourusername/your-repo-name",
  "env": {
    "API_ID": { "description": "API_ID", "required": true },
    "API_HASH": { "description": "API_HASH", "required": true },
    "STRING_SESSION": { "description": "Pyrogram String Session", "required": true },
    "TARGET_LINK": { "description": "Post link (e.g., https://t.me/username/123)", "required": true },
    "REASON": { "description": "spam, violence, etc.", "value": "spam" }
  },
  "formation": {
    "worker": {
      "quantity": 1
    }
  },
  "buildpacks": [{ "url": "heroku/python" }]
}
